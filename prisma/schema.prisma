generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Tables ─────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           String    @default("user")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  clients  Client[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AiPlatform {
  chatgpt
  perplexity
  google_ai
  gemini
  copilot
}

enum SentimentType {
  positive
  neutral
  negative
}

enum DirectoryPlatform {
  google
  yelp
  foursquare
  bing
  apple_maps
  facebook
}

enum OnboardingStatus {
  scan_complete
  setup_pending
  setup_running
  setup_complete
  active
}

enum Plan {
  free_scan
  starter
  growth
}

enum FileType {
  llms_txt
  schema_json
}

// ─── Domain Tables ───────────────────────────────────────────────────────────

model Client {
  id                    String           @id @default(uuid())
  businessName          String
  websiteUrl            String
  city                  String
  state                 String?
  phone                 String?
  address               String?
  category              String?
  services              String[]
  hours                 String?
  googleBusinessUrl     String?
  onboardingStatus      OnboardingStatus @default(scan_complete)
  plan                  Plan             @default(free_scan)
  stripeCustomerId      String?          @unique
  stripeSubscriptionId  String?          @unique
  userId                String           @unique
  lastRecheckAt         DateTime?
  lastRegenerateAt      DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user               User               @relation(fields: [userId], references: [id])
  queries            Query[]
  citations          Citation[]
  visibilityScores   VisibilityScore[]
  competitors        Competitor[]
  napAudits          NapAudit[]
  reviewSnapshots    ReviewSnapshot[]
  generatedFiles     GeneratedFile[]
  industrySources    IndustrySource[]
  adminNotes         AdminNote[]
  scanReports        ScanReport[]

  @@index([userId])
}

model Query {
  id              String   @id @default(uuid())
  clientId        String
  queryText       String
  isAutoGenerated Boolean  @default(true)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client              Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  citations           Citation[]
  competitorCitations CompetitorCitation[]

  @@index([clientId])
}

model Citation {
  id          String        @id @default(uuid())
  clientId    String
  queryId     String
  platform    AiPlatform
  cited       Boolean       @default(false)
  position    Int?
  sentiment   SentimentType?
  rawResponse String?       @db.Text
  sourcesCited Json         @default("[]")
  checkedAt   DateTime      @default(now())
  createdAt   DateTime      @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  query  Query  @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, platform])
  @@index([queryId])
}

model VisibilityScore {
  id               String   @id @default(uuid())
  clientId         String
  score            Int
  queryCoverage    Int
  platformCoverage Int
  period           DateTime
  breakdown        Json     @default("{}")
  createdAt        DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, period])
  @@index([clientId])
  @@index([clientId, period])
}

model Competitor {
  id             String   @id @default(uuid())
  clientId       String
  competitorName String
  competitorUrl  String?
  isAutoDetected Boolean  @default(false)
  createdAt      DateTime @default(now())

  client              Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  competitorCitations CompetitorCitation[]

  @@index([clientId])
}

model CompetitorCitation {
  id           String     @id @default(uuid())
  competitorId String
  queryId      String
  platform     AiPlatform
  cited        Boolean    @default(false)
  position     Int?
  rawResponse  String?    @db.Text
  checkedAt    DateTime   @default(now())
  createdAt    DateTime   @default(now())

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  query      Query      @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([competitorId, platform])
}

model NapAudit {
  id           String            @id @default(uuid())
  clientId     String
  platform     DirectoryPlatform
  nameMatch    Boolean?
  addressMatch Boolean?
  phoneMatch   Boolean?
  listingUrl   String?
  issues       String[]
  checkedAt    DateTime          @default(now())
  createdAt    DateTime          @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, platform])
}

model ReviewSnapshot {
  id          String            @id @default(uuid())
  clientId    String
  platform    DirectoryPlatform
  rating      Float?
  reviewCount Int?
  checkedAt   DateTime          @default(now())
  createdAt   DateTime          @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, platform])
}

model GeneratedFile {
  id        String   @id @default(uuid())
  clientId  String
  fileType  FileType
  content   String   @db.Text
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model IndustrySource {
  id             String       @id @default(uuid())
  clientId       String
  domain         String
  url            String?
  citationCount  Int          @default(0)
  platformsCiting AiPlatform[]
  period         DateTime
  createdAt      DateTime     @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, period])
}

model AdminNote {
  id        String   @id @default(uuid())
  clientId  String
  author    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model SharedReport {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  data      Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model ScanReport {
  id        String   @id @default(uuid())
  clientId  String
  url       String
  score     Int
  data      Json
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, createdAt])
}
